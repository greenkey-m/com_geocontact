<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset addfieldpath="/components/com_geocontact/models/fields">

        <field name="id" type="text" default="0" label="COM_GEOCONTACT_FORM_LBL_GEOCONTACT_ID"
               readonly="true" class="readonly"
               description="JGLOBAL_FIELD_ID_DESC" />

        <field
            name="caption"
            type="textfield"
            label="COM_GEOCONTACT_GEOCONTACT_CAPTION_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_CAPTION_DESC"
            default=""
        />

        <field
            name="alias"
            type="textfield"
            label="COM_GEOCONTACT_GEOCONTACT_ALIAS_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_ALIAS_DESC"
            default=""
        />

        <field
            name="description"
            type="editor"
            label="COM_GEOCONTACT_GEOCONTACT_DESCRIPTION_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_DESCRIPTION_DESC"
            filter="raw"
            default=""
        />

        <field
            name="stand"
            type="textfield"
            label="COM_GEOCONTACT_GEOCONTACT_STAND_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_STAND_DESC"
            default=""
        />

        <field
            name="address"
            type="textfield"
            label="COM_GEOCONTACT_GEOCONTACT_ADDRESS_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_ADDRESS_DESC"
            default=""
        />

        <field
            name="name"
            type="textfield"
            label="COM_GEOCONTACT_GEOCONTACT_NAME_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_NAME_DESC"
            default=""
        />

        <field
            name="phones"
            type="textfield"
            label="COM_GEOCONTACT_GEOCONTACT_PHONES_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_PHONES_DESC"
            default=""
        />

        <field
            name="latlong"
            type="textfield"
            label="COM_GEOCONTACT_GEOCONTACT_LATLONG_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_LATLONG_DESC"
            default=""
        />

        <field
            name="catid"
            type="category"
            extension="com_geocontact"
            class="inputbox"
            default=""
            label="COM_GEOCONTACT_GEOCONTACT_FIELD_CATID_LABEL"
            description="COM_GEOCONTACT_GEOCONTACT_FIELD_CATID_DESC"
            required="true"
        >
            <option value="0">JOPTION_SELECT_CATEGORY</option>
        </field>

        <field
            name="created_by"
            type="createdby"
            label="COM_GEOCONTACT_GEOCONTACT_CREATED_BY_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_CREATED_BY_DESC"
            default=""
        />

        <field
            name="state"
            class="inputbox"
            size="1"
            type="list"
            label="COM_GEOCONTACT_GEOCONTACT_STATE_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_STATE_DESC"
            default="1"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="2">JARCHIVED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <field
            name="ordering"
            type="hidden"
            label="COM_GEOCONTACT_GEOCONTACT_ORDERING_LBL"
            description="COM_GEOCONTACT_GEOCONTACT_ORDERING_DESC"
            default=""
        />

        <field
            name="tagfieldname"
            type="tag"
            mode="ajax"
            label="COM_GEOCONTACT_GEOCONTACT_TAG_FIELD_NAME"
            description="COM_GEOCONTACT_GEOCONTACT_TAG_FIELD_NAME_DESC"
            multiple="true"
            custom="allow"
            required="false"
        />

    </fieldset>
</form>
