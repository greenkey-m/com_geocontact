<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_geocontact</name>
    <creationDate>2018-08-03</creationDate>
    <copyright>Copyright (C) 2025. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <author>Matvey Rumynin</author>
    <authorEmail>info@greenkey.ru</authorEmail>
    <authorUrl>http://geocontact.greenkey.ru</authorUrl>
    <version>5.0.0</version>
    <description>Geo + contact list</description>
    <namespace path="src">Greenkey\Component\Geocontact</namespace>

    <!-- Runs on install -->
    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>
    
    <!-- Runs on uninstall -->
    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <files folder="site">
        <folder>assets</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>
    <languages folder="language">
        <language tag="en-GB">site/en-GB/com_geocontact.ini</language>
		<language tag="ru-RU">site/ru-RU/com_geocontact.ini</language>
    </languages>
    <administration>
        <menu img="components/com_geocontact/assets/images/main-16x16-geocontact.png">COM_GEOCONTACT</menu>
        <submenu>
            <menu link="option=com_geocontact&amp;view=geocontacts" view="geocontacts" img="components/com_geocontact/assets/images/view-16x16-geocontacts.png" alt="Geocontact/Geocontacts">COM_GEOCONTACT_TITLE_GEOCONTACTS</menu>
            <menu link="option=com_categories&amp;extension=com_geocontact">JCATEGORIES</menu>
        </submenu>
        <files folder="administrator">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <folder>assets</folder>
            <folder>tmpl</folder>
            <folder>forms</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
        </files>
        <languages folder="language">
            <language tag="en-GB">administrator/en-GB/com_geocontact.ini</language>
			<language tag="en-GB">administrator/en-GB/com_geocontact.sys.ini</language>
			<language tag="ru-RU">administrator/ru-RU/com_geocontact.ini</language>
			<language tag="ru-RU">administrator/ru-RU/com_geocontact.sys.ini</language>
        </languages>
    </administration>
    <!-- Generated with the ComponentGenerator.com -->
</extension>
